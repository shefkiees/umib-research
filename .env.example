DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DB_SSL=true
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT=5000

CLIENT_URL=https://umibres.page
SESSION_SECRET=replace-with-a-long-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://umibres.page/api/auth/google/callback
REQUIRE_DB_USER_SYNC=true

# Use the API origin plus /api in production, for example:
# VITE_API_BASE_URL=https://www.umibres.page/api
VITE_API_BASE_URL=

# Backend-only Supabase Admin API for administrator-managed auth provisioning.
# Never expose the service role key in frontend env.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PASSWORD_RESET_REDIRECT_URL=https://www.umibres.page/auth/reset-password

# Optional email delivery for in-app notifications when users enable email notifications.
# Resend is used via HTTPS, so no extra npm package is required.
RESEND_API_KEY=
EMAIL_FROM=UMIBRes <notifications@your-domain.com>
ACCESS_RESET_NOTIFY_EMAILS=it@umib.net,admin@umib.net
RESEND_ACCESS_RESET_TEMPLATE_ID=
